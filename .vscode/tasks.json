{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Start Backend",
            "type": "shell",
            "command": "node server.js",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "." },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Сервер запущений"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "fullstack"
            }
        },
        {
            "label": "🌐 Open Browser",
            "type": "shell",
            "command": "start http://localhost:5000",
            "dependsOn": ["🚀 Start Backend"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "🎯 Full Stack — Start",
            "dependsOn": ["🚀 Start Backend", "🌐 Open Browser"],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "⚙️ Backend Dev (nodemon)",
            "type": "shell",
            "command": "npx nodemon server.js",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "." },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Сервер запущений"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "🗄️ Init Database",
            "type": "shell",
            "command": "node init-sqlite.js",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
